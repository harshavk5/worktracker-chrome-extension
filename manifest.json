{
  "manifest_version": 3,
  "name": "Productivity Tracker",
  "version": "1.1.0",
  "description": "Log what you're working on every 15/30 min. Export to CSV weekly.",

  "permissions": [
    "alarms",
    "storage",
    "notifications",
    "downloads",
    "tabs"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Productivity Tracker",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["logger.html"],
      "matches":   ["<all_urls>"]
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
